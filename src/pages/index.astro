---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Brands from '../components/Brands.astro';
import Services from '../components/Services.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import About from '../components/About.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import { generateHvacSchema } from '../utils/schema.js';

const siteUrl = Astro.site ? Astro.site.href : 'https://hvac-volos.gr';
const schemaData = generateHvacSchema(siteUrl);
---

<BaseLayout 
  title="CoolingEnergy - Γιώργος Μούτος | Ψύξη - Θέρμανση Βόλος & Πήλιο"
  description="Πιστοποιημένος ψυκτικός Γιώργος Μούτος (CoolingEnergy), Νέα Ιωνία Βόλου. Εγκαταστάσεις A/C, αντλίες θερμότητας & συντήρηση σε Βόλο & Πήλιο."
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(schemaData)} />

  <Header />
  <Hero />
  <Services />
  <Brands />
  <ServiceAreas />
  <About />
  <ContactForm />
  <Footer />
</BaseLayout>