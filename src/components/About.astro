---
// src/components/About.astro
import { businessInfo } from '../data/businessInfo.js';
---

<section id="about" class="py-16 md:py-24 bg-slate-900 text-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Technician Photo Slot -->
      <div class="lg:col-span-5">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-slate-700/80 group">
          <!-- Replace this placeholder with a real photo of Giorgos (e.g., /images/giorgos-moutos.jpg) -->
          <img 
            src="/images/giorgos-moutos.jpg" 
            alt="Γιώργος Μούτος - Πιστοποιημένος Ψυκτικός Βόλος"
            class="w-full h-[450px] object-cover object-center group-hover:scale-105 transition-transform duration-500"
            onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=800&q=80';"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-transparent to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6">
            <span class="text-xs font-bold uppercase tracking-wider text-blue-400 bg-blue-950/80 px-3 py-1 rounded-full border border-blue-800/50">
              Πιστοποιημενος Τεχνικος HVAC
            </span>
            <h3 class="text-2xl font-bold mt-2">Γιώργος Μούτος</h3>
            <p class="text-sm text-slate-300">Ιδρυτής & Τεχνικός Υπεύθυνος CoolingEnergy</p>
          </div>
        </div>
      </div>

      <!-- Bio & Qualifications Content -->
      <div class="lg:col-span-7 space-y-6">
        <div>
          <span class="text-blue-400 font-bold text-xs uppercase tracking-widest">
            Σχετικα με εμας
          </span>
          <h2 class="text-3xl sm:text-4xl font-extrabold mt-1 text-white">
            Προσωπική Φροντίδα & Επαγγελματική Αξιοπιστία
          </h2>
        </div>

        <p class="text-slate-300 leading-relaxed">
          Ο <strong>Γιώργος Μούτος</strong>, πιστοποιημένος ψυκτικός με πολυετή εξειδίκευση στα συστήματα κλιματισμού και θέρμανσης, βρίσκεται πίσω από την <strong>CoolingEnergy</strong>. Με έδρα τη Νέα Ιωνία Βόλου, καλύπτει άμεσα κάθε τεχνική ανάγκη σε ολόκληρο το πολεοδομικό συγκρότημα του Βόλου και τα χωριά του Πηλίου.
        </p>

        <p class="text-slate-300 leading-relaxed">
          Κάθε εγκατάσταση και συντήρηση πραγματοποιείται με βάση τις αυστηρότερες ευρωπαϊκές προδιαγραφές, εξασφαλίζοντας μέγιστη εξοικονόμηση ενέργειας και μεγάλη διάρκεια ζωής για τις συσκευές σας.
        </p>

        <!-- Highlights Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
          <div class="p-4 rounded-xl bg-slate-800/60 border border-slate-700/60 flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-blue-600/20 text-blue-400 flex items-center justify-center shrink-0">
              ✔
            </div>
            <div>
              <h4 class="text-sm font-bold text-white">Επίσημη Πιστοποίηση</h4>
              <p class="text-xs text-slate-400 mt-0.5">Αδειούχος ψυκτικός με εξειδίκευση στα οικολογικά ψυκτικά υγρά.</p>
            </div>
          </div>

          <div class="p-4 rounded-xl bg-slate-800/60 border border-slate-700/60 flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-blue-600/20 text-blue-400 flex items-center justify-center shrink-0">
              📍
            </div>
            <div>
              <h4 class="text-sm font-bold text-white">Έδρα: Νέα Ιωνία Βόλου</h4>
              <p class="text-xs text-slate-400 mt-0.5">Άμεση απόκριση σε Βόλο & όλα τα χωριά του Πηλίου.</p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</section>