---
// src/components/Services.astro
import { servicesData } from '../data/services.js';
import { businessInfo } from '../data/businessInfo.js';

// Fallback image map based on service index/ID if service object missing explicit image
const defaultImages = [
  'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1581094288338-2314dddb7ece?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1585704032915-c3400ca199e7?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1610557892470-55d9e80c0bce?auto=format&fit=crop&w=1200&q=80',
];

// Enrich imported servicesData with fallback defaults for missing optional fields
const services = servicesData.map((s, idx) => ({
  ...s,
  id: s.id || `service-${idx}`,
  tag: s.tag || s.categoryLabel || 'Τεχνική Υπηρεσία',
  image: s.image || defaultImages[idx % defaultImages.length],
  features: s.features || [
    'Εξειδικευμένο προσωπικό με πολυετή εμπειρία',
    'Πιστοποιημένα υλικά & αυθεντικά ανταλλακτικά',
    'Γραπτή εγγύηση καλής λειτουργίας'
  ]
}));
---

<section id="services" class="py-16 md:py-24 bg-slate-100/70 relative border-y border-slate-200 overflow-hidden">
  
  <!-- Subtle Ambient Glow -->
  <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-3/4 h-96 bg-blue-500/10 blur-[130px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-10 md:mb-14 space-y-3">
      <div class="inline-flex items-center gap-2 px-3.5 py-1 rounded-full bg-blue-50 border border-blue-200/80 text-blue-700 text-xs font-bold uppercase tracking-widest">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse"></span>
        Υπηρεσιες HVAC & Υδραυλικα
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-slate-900 tracking-tight">
        Επιλέξτε Υπηρεσία
      </h2>
      <p class="text-slate-600 text-base sm:text-lg">
        Πατήστε πάνω σε μια κατηγορία για να δείτε αναλυτικά τις τεχνικές κάλυψεις, τον εξοπλισμό και τις παρεχόμενες εγγυήσεις.
      </p>
    </div>

    <!-- Main Interactive Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-start">
      
      <!-- Mobile Horizontal Scroll Tabs / Desktop Vertical Sidebar -->
      <div class="lg:col-span-4 flex lg:flex-col gap-3 overflow-x-auto pb-4 lg:pb-0 scrollbar-none snap-x snap-mandatory">
        {services.map((item, index) => (
          <button
            data-index={index}
            class={`service-item group snap-start flex-shrink-0 lg:flex-shrink w-[260px] sm:w-[300px] lg:w-full text-left p-4 sm:p-5 rounded-2xl transition-all duration-300 border cursor-pointer ${
              index === 0
                ? 'active-item bg-white border-blue-600 shadow-md ring-2 ring-blue-600/20'
                : 'bg-white/70 hover:bg-white border-slate-200/90 hover:border-slate-300'
            }`}
          >
            <div class="flex items-center justify-between w-full">
              <div class="space-y-1 pr-2">
                <span class="text-[11px] font-bold text-blue-600 tracking-wider uppercase block">
                  {item.tag}
                </span>
                <h3 class="text-base sm:text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors">
                  {item.title}
                </h3>
              </div>
              
              <div class="w-8 h-8 rounded-xl bg-slate-100 group-hover:bg-blue-600 group-hover:text-white text-slate-400 flex items-center justify-center flex-shrink-0 transition-all duration-300">
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </button>
        ))}
      </div>

      <!-- Feature Showcase Area (Non-Card Landing View) -->
      <div class="lg:col-span-8">
        <div class="relative rounded-3xl bg-white border border-slate-200/80 shadow-xl overflow-hidden">
          
          <!-- Large Top Image with Gradient Overlay -->
          <div class="relative h-64 sm:h-80 md:h-96 w-full bg-slate-900 overflow-hidden">
            <img 
              id="showcase-img" 
              src={services[0].image} 
              alt={services[0].title}
              class="w-full h-full object-cover transition-all duration-500 transform scale-100"
            />
            
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent"></div>

            <!-- Floating Top Pills -->
            <div class="absolute top-4 left-4 sm:top-6 sm:left-6 flex items-center gap-2">
              <span id="showcase-tag" class="px-3 py-1.5 rounded-xl bg-white/95 backdrop-blur-md text-slate-900 text-xs font-bold shadow-sm border border-white">
                {services[0].tag}
              </span>
            </div>

            <!-- Overlay Title on Image -->
            <div class="absolute bottom-6 left-6 right-6 space-y-1">
              <h3 id="showcase-title" class="text-2xl sm:text-3xl lg:text-4xl font-black text-white tracking-tight">
                {services[0].title}
              </h3>
            </div>
          </div>

          <!-- Showcase Content Section -->
          <div class="p-6 sm:p-8 md:p-10 space-y-8">
            
            <!-- Main Description -->
            <div class="space-y-3">
              <h4 class="text-xs font-extrabold uppercase tracking-widest text-blue-600">
                Περιγραφη Εργασιων
              </h4>
              <p id="showcase-desc" class="text-slate-700 text-base sm:text-lg leading-relaxed font-normal">
                {services[0].description}
              </p>
            </div>

            <hr class="border-slate-100" />

            <!-- Features Grid -->
            <div class="space-y-4">
              <h4 class="text-xs font-extrabold uppercase tracking-widest text-slate-400">
                Τι περιλαμβανει η υπηρεσια
              </h4>
              
              <ul id="showcase-features" class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
                {services[0].features.map((feat) => (
                  <li class="flex items-start gap-3 p-3.5 rounded-xl bg-slate-50 border border-slate-100/80">
                    <div class="w-6 h-6 rounded-lg bg-emerald-500 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5 shadow-xs">
                      ✓
                    </div>
                    <span class="text-sm font-semibold text-slate-800 leading-snug">{feat}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Bottom CTA Banner -->
            <div class="pt-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-t border-slate-100">
              <div class="space-y-0.5">
                <span class="text-xs font-bold text-slate-900 block">Χρειάζεστε τεχνικό έλεγχο ή προσφορά;</span>
                <span class="text-xs text-slate-500">Άμεση εξυπηρέτηση σε Βόλο, Πήλιο & γύρω περιοχές.</span>
              </div>

              <a 
                href={`tel:${businessInfo.phone}`} 
                class="w-full sm:w-auto px-6 py-3.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow-lg shadow-blue-600/20 transition-all flex items-center justify-center gap-2 group/btn"
              >
                <span>Καλέστε στο {businessInfo.phone}</span>
                <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>

          </div>

        </div>
      </div>

    </div>

  </div>
</section>

<!-- Interactive Dynamic Switching Script -->
<script is:inline define:vars={{ services }}>
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.service-item');
    const img = document.getElementById('showcase-img');
    const tag = document.getElementById('showcase-tag');
    const title = document.getElementById('showcase-title');
    const desc = document.getElementById('showcase-desc');
    const features = document.getElementById('showcase-features');

    items.forEach((item) => {
      item.addEventListener('click', () => {
        const index = parseInt(item.getAttribute('data-index') || '0', 10);
        const data = services[index];

        if (!data) return;

        // Active State Button Classes
        items.forEach((i) => {
          i.classList.remove('active-item', 'bg-white', 'border-blue-600', 'shadow-md', 'ring-2', 'ring-blue-600/20');
          i.classList.add('bg-white/70', 'border-slate-200/90');
        });
        
        item.classList.remove('bg-white/70', 'border-slate-200/90');
        item.classList.add('active-item', 'bg-white', 'border-blue-600', 'shadow-md', 'ring-2', 'ring-blue-600/20');

        // Smooth Opacity Swap
        if (img) {
          img.style.opacity = '0.4';
          img.style.transform = 'scale(0.98)';
        }

        setTimeout(() => {
          if (img) {
            img.src = data.image;
            img.alt = data.title;
            img.style.opacity = '1';
            img.style.transform = 'scale(1)';
          }
          if (tag) tag.textContent = data.tag;
          if (title) title.textContent = data.title;
          if (desc) desc.textContent = data.description;
          
          if (features && Array.isArray(data.features)) {
            features.innerHTML = data.features.map(f => `
              <li class="flex items-start gap-3 p-3.5 rounded-xl bg-slate-50 border border-slate-100/80">
                <div class="w-6 h-6 rounded-lg bg-emerald-500 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5 shadow-xs">
                  ✓
                </div>
                <span class="text-sm font-semibold text-slate-800 leading-snug">${f}</span>
              </li>
            `).join('');
          }
        }, 150);
      });
    });
  });
</script>

<style>
  /* Hide scrollbar for clean horizontal swipe on mobile */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>