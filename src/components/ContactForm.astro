---
// src/components/ContactForm.astro
import { businessInfo } from '../data/businessInfo.js';

// Get free access key from https://web3forms.com
const WEB3FORMS_ACCESS_KEY = "YOUR_WEB3FORMS_ACCESS_KEY"; 
---

<section id="contact" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <!-- Left Column: Contact Info & Benefits -->
      <div class="lg:col-span-5 space-y-6">
        <span class="inline-block px-3.5 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold uppercase tracking-wider">
          Επικοινωνια
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">
          Χρειάζεστε τεχνικό σε Βόλο ή Πήλιο;
        </h2>
        <p class="text-slate-600 leading-relaxed">
          Συμπληρώστε τη φόρμα για να ζητήσετε προσφορά ή προγραμματισμό επίσκεψης. Για επείγουσες βλάβες, καλέστε μας απευθείας στο τηλέφωνο.
        </p>

        <!-- Direct Contact Badges -->
        <div class="space-y-4 pt-4">
          <a href={`tel:${businessInfo.phone}`} class="flex items-center gap-4 p-4 rounded-xl bg-slate-50 border border-slate-200 hover:border-blue-500 transition-colors group">
            <div class="w-12 h-12 rounded-lg bg-blue-600 text-white flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 font-medium">Τηλέφωνο Άμεσης Ανάγκης</p>
              <p class="text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors">{businessInfo.phoneFormatted}</p>
            </div>
          </a>

          <div class="flex items-center gap-4 p-4 rounded-xl bg-slate-50 border border-slate-200">
            <div class="w-12 h-12 rounded-lg bg-emerald-600 text-white flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 font-medium">Περιοχή Εξυπηρέτησης</p>
              <p class="text-sm font-bold text-slate-900">Βόλος, Νέα Ιωνία & Όλα τα χωριά Πηλίου</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Web3Forms Contact Form -->
      <div class="lg:col-span-7 bg-slate-50 p-6 sm:p-8 rounded-2xl border border-slate-200/80 shadow-sm">
        
        <form id="contact-form" class="space-y-4">
          <!-- Required Web3Forms Access Key -->
          <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
          
          <!-- Subject Line in Received Email -->
          <input type="hidden" name="subject" value="Νέο Αίτημα Επικοινωνίας - HVAC Website" />
          
          <!-- Anti-Spam Honeypot (Hidden from human users) -->
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Name Input -->
            <div>
              <label for="name" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">
                Ονοματεπώνυμο *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="π.χ. Γιάννης Παπαδόπουλος"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none text-sm transition-all"
              />
            </div>

            <!-- Phone Input -->
            <div>
              <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">
                Τηλέφωνο Επικοινωνίας *
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder="69XXXXXXXX"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none text-sm transition-all"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Location Input -->
            <div>
              <label for="location" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">
                Περιοχή / Χωριό *
              </label>
              <input
                type="text"
                id="location"
                name="location"
                required
                placeholder="π.χ. Βόλος ή Πορταριά"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none text-sm transition-all"
              />
            </div>

            <!-- Service Selection -->
            <div>
              <label for="service" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">
                Υπηρεσία
              </label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none text-sm transition-all bg-white"
              >
                <option value="Συντήρηση / Εγκατάσταση A/C">Συντήρηση / Εγκατάσταση A/C</option>
                <option value="Αντλία Θερμότητας">Αντλία Θερμότητας</option>
                <option value="Συντήρηση Λέβητα / Θέρμανση">Συντήρηση Λέβητα / Θέρμανση</option>
                <option value="Έκτακτη Βλάβη">Έκτακτη Βλάβη (24/7)</option>
              </select>
            </div>
          </div>

          <!-- Message Textarea -->
          <div>
            <label for="message" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">
              Περιγραφή Εργασίας
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Περιγράψτε εν συντομία την εργασία ή το πρόβλημα..."
              class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none text-sm transition-all resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full py-4 px-6 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold text-base shadow-lg shadow-blue-600/20 transition-all flex items-center justify-center gap-2 active:scale-95 disabled:opacity-50"
          >
            <span>Αποστολή Αιτήματος</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>

          <!-- Response Message Alert -->
          <div id="form-result" class="hidden p-4 rounded-xl text-sm text-center font-medium"></div>

        </form>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  // Plain JS handler for submitting without page reload
  const form = document.getElementById('contact-form');
  const result = document.getElementById('form-result');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.innerText = 'Αποστολή...';

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
      },
      body: json,
    })
      .then(async (response) => {
        let jsonResponse = await response.json();
        result.classList.remove('hidden', 'bg-red-100', 'text-red-700');
        
        if (response.status === 200) {
          result.classList.add('bg-emerald-100', 'text-emerald-800');
          result.innerHTML = '✔ Το μήνυμά σας στάλθηκε επιτυχώς! Θα επικοινωνήσουμε μαζί σας σύντομα.';
          form.reset();
        } else {
          result.classList.add('bg-red-100', 'text-red-700');
          result.innerHTML = jsonResponse.message || 'Κάτι πήγε λάθος. Παρακαλούμε καλέστε μας τηλεφωνικά.';
        }
      })
      .catch((error) => {
        result.classList.remove('hidden');
        result.classList.add('bg-red-100', 'text-red-700');
        result.innerHTML = 'Σφάλμα δικτύου. Παρακαλούμε προσπαθήστε ξανά ή καλέστε μας.';
      })
      .then(function () {
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<span>Αποστολή Αιτήματος</span> <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>`;
      });
  });
</script>