---
// src/components/ServiceAreas.astro
import { businessInfo } from '../data/businessInfo.js';

const mainRegions = [
  {
    id: 'volos',
    title: 'Βόλος & Αστική Περιοχή',
    response: 'Άμεση επέμβαση εντός 30\'-60\'',
    description: 'Πλήρης τεχνική κάλυψη για κατοικίες, καταστήματα και επαγγελματικούς χώρους στο πολεοδομικό συγκρότημα Βόλου.',
    areas: [
      'Κέντρο Βόλου',
      'Νέα Ιωνία',
      'Άναυρος',
      'Νέα Δημητριάδα',
      'Αγία Παρασκευή',
      'Μεταμόρφωση',
      'Αλυκές',
      'Παλαιά'
    ]
  },
  {
    id: 'suburbs',
    title: 'Προάστια & Παράλια',
    response: 'Αυθημερόν εξυπηρέτηση',
    description: 'Εγκαταστάσεις και προληπτικές συντηρήσεις σε παραθαλάσσιες και περιφερειακές περιοχές της Μαγνησίας.',
    areas: [
      'Αγριά',
      'Άνω Λεχώνια',
      'Κάτω Λεχώνια',
      'Καλά Νερά',
      'Διμήνι',
      'Σέσκλο',
      'Βελεστίνο',
      'Αγχίαλος'
    ]
  },
  {
    id: 'pelion',
    title: 'Ορεινό Πήλιο',
    response: 'Προγραμματισμένα & Εκτακτα 24/7',
    description: 'Εξειδικευμένες λύσεις θέρμανσης, αντλιών θερμότητας & λεβήτων για οικίες, ξενώνες και ξενοδοχεία στο Πήλιο.',
    areas: [
      'Πορταριά',
      'Μακρινίτσα',
      'Χάνια (Χιονοδρομικό)',
      'Ζαγορά',
      'Τσαγκαράδα',
      'Μηλιές',
      'Βυζίτσα',
      'Άγιος Ιωάννης'
    ]
  }
];
---

<section id="service-areas" class="py-20 md:py-28 bg-white border-b border-slate-200/80 relative overflow-hidden">
  
  <!-- Subtle Background Pattern -->
  <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px] opacity-40 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-14 space-y-4">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-blue-50 border border-blue-200/80 text-blue-700 text-xs font-bold uppercase tracking-widest">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span>
        Περιοχες Εξυπηρετησης
      </div>

      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-slate-900 tracking-tight">
        Τεχνική Υποστήριξη σε <br class="hidden sm:inline"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-blue-500 to-cyan-600">
          Βόλο, Πήλιο & Μαγνησία
        </span>
      </h2>

      <p class="text-slate-600 text-base sm:text-lg leading-relaxed">
        Διαθέτουμε κινητά συνεργεία εξοπλισμένα με όλα τα απαραίτητα ανταλλακτικά για άμεση κάλυψη βλαβών σε αστικές και ορεινές περιοχές.
      </p>
    </div>

    <!-- Interactive Tabs -->
    <div class="flex items-center gap-3 mb-10 overflow-x-auto pb-2 scrollbar-none snap-x">
      {mainRegions.map((region, idx) => (
        <button
          data-target={region.id}
          class={`area-tab snap-start px-5 py-3 rounded-2xl text-sm font-bold transition-all duration-300 border cursor-pointer whitespace-nowrap flex items-center gap-2 ${
            idx === 0
              ? 'active-area-tab bg-blue-600 text-white border-blue-600 shadow-lg shadow-blue-600/20'
              : 'bg-slate-50 text-slate-700 border-slate-200/80 hover:bg-slate-100 hover:text-slate-900'
          }`}
        >
          <svg class="w-4 h-4 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>{region.title}</span>
        </button>
      ))}
    </div>

    <!-- Region Content Panels -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      
      {mainRegions.map((region, idx) => (
        <div 
          id={`region-panel-${region.id}`}
          class={`area-panel lg:col-span-12 grid grid-cols-1 lg:grid-cols-12 gap-8 bg-slate-50 border border-slate-200/90 rounded-3xl p-6 sm:p-8 md:p-10 transition-all duration-500 ${
            idx === 0 ? 'block' : 'hidden'
          }`}
        >
          
          <!-- Left Info Column -->
          <div class="lg:col-span-5 space-y-6 flex flex-col justify-between">
            <div class="space-y-4">
              <span class="inline-flex items-center gap-2 px-3 py-1 rounded-xl bg-emerald-100 text-emerald-800 text-xs font-bold">
                <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {region.response}
              </span>

              <h3 class="text-2xl sm:text-3xl font-black text-slate-900">
                {region.title}
              </h3>

              <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
                {region.description}
              </p>
            </div>

            <!-- Quick Direct Call Card -->
            <div class="p-5 rounded-2xl bg-white border border-slate-200 shadow-sm space-y-3">
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block">Χρειάζεστε άμεση τεχνική κάλυψη;</span>
              <div class="flex items-center justify-between gap-3">
                <span class="text-base font-extrabold text-slate-900">{businessInfo.phone}</span>
                <a 
                  href={`tel:${businessInfo.phone}`}
                  class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs shadow-md transition-all inline-flex items-center gap-1.5"
                >
                  <span>Κλήση</span>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              </div>
            </div>

          </div>

          <!-- Right Areas Grid -->
          <div class="lg:col-span-7 bg-white rounded-2xl p-6 border border-slate-200/80 shadow-xs flex flex-col justify-between space-y-6">
            <div>
              <h4 class="text-xs font-extrabold text-slate-400 uppercase tracking-widest mb-4">
                Περιοχές & Οικισμοί που εξυπηρετούμε:
              </h4>

              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {region.areas.map((area) => (
                  <div class="flex items-center gap-2.5 p-2.5 rounded-xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:bg-blue-50/50 transition-colors">
                    <span class="w-2 h-2 rounded-full bg-blue-600"></span>
                    <span class="text-xs sm:text-sm font-bold text-slate-800">{area}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="pt-4 border-t border-slate-100 flex items-center gap-2 text-xs text-slate-500 font-medium">
              <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Δεν βλέπετε την περιοχή σας; Καλέστε μας για επιβεβαίωση κάλυψης.</span>
            </div>

          </div>

        </div>
      ))}

    </div>

  </div>
</section>

<!-- Tab Switcher Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.area-tab');
    const panels = document.querySelectorAll('.area-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-target');

        // Toggle active tab style
        tabs.forEach(t => {
          t.classList.remove('active-area-tab', 'bg-blue-600', 'text-white', 'border-blue-600', 'shadow-lg', 'shadow-blue-600/20');
          t.classList.add('bg-slate-50', 'text-slate-700', 'border-slate-200/80');
        });

        tab.classList.remove('bg-slate-50', 'text-slate-700', 'border-slate-200/80');
        tab.classList.add('active-area-tab', 'bg-blue-600', 'text-white', 'border-blue-600', 'shadow-lg', 'shadow-blue-600/20');

        // Toggle panels
        panels.forEach(panel => {
          if (panel.id === `region-panel-${targetId}`) {
            panel.classList.remove('hidden');
            panel.classList.add('block');
          } else {
            panel.classList.remove('block');
            panel.classList.add('hidden');
          }
        });
      });
    });
  });
</script>